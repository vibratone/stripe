{\n  "name": "Stripe Checkout Session",\n  "description": "Creates a Stripe Checkout Session via Make.com webhook and redirects to the hosted checkout URL.",\n  "author": "Vibratone",\n  "params": [\n    { "name": "webhook_url", "displayName": "Make Webhook URL", "type": "string" },\n    { "name": "mode", "displayName": "Mode (payment/subscription)", "type": "string", "defaultValue": "payment" },\n    { "name": "success_url", "displayName": "Success URL", "type": "string" },\n    { "name": "cancel_url", "displayName": "Cancel URL", "type": "string" },\n    { "name": "customer_email", "displayName": "Customer Email", "type": "string" },\n    { "name": "client_reference_id", "displayName": "Client Reference ID", "type": "string" },\n    { "name": "line_items", "displayName": "Line Items (JSON)", "type": "string" },\n    { "name": "discounts", "displayName": "Discounts (JSON)", "type": "string" },\n    { "name": "metadata", "displayName": "Metadata (JSON)", "type": "string" },\n    { "name": "invoice_creation", "displayName": "Invoice Creation (JSON)", "type": "string" },\n    { "name": "payment_intent_data", "displayName": "Payment Intent Data (JSON)", "type": "string" },\n    { "name": "subscription_data", "displayName": "Subscription Data (JSON)", "type": "string" },\n    { "name": "locale", "displayName": "Locale", "type": "string" },\n    { "name": "billing_address_collection", "displayName": "Billing Address Collection", "type": "string" },\n    { "name": "phone_number_collection", "displayName": "Phone Number Collection (JSON)", "type": "string" },\n    { "name": "shipping_address_collection", "displayName": "Shipping Address Collection (JSON)", "type": "string" },\n    { "name": "allow_promotion_codes", "displayName": "Allow Promotion Codes", "type": "string" },\n    { "name": "automatic_tax", "displayName": "Automatic Tax (JSON)", "type": "string" },\n    { "name": "tax_id_collection", "displayName": "Tax ID Collection (JSON)", "type": "string" },\n    { "name": "payment_method_types", "displayName": "Payment Method Types (JSON)", "type": "string" },\n    { "name": "expires_at", "displayName": "Expires At (Unix timestamp)", "type": "string" }\n  ],\n  "result": {\n    "type": "string",\n    "displayName": "Checkout Frame (Data URI)"\n  }\n}